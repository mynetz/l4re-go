<?xml version="1.0" encoding="UTF-8"?>
<!--
  Vendored L4Re manifest for the l4re-go-prj integration project.

  Upstream:    https://github.com/L4Re/manifest
  Branch:      main
  Commit SHA:  5ff21e46799a4f333fb5ebc5a44d89c76474101b
  Fetched:     2026-05-06

  Transformations applied vs. upstream:
    1. Path rename:
         every  path="l4"        becomes  path="l4re"
         every  path="l4/..."    becomes  path="l4re/..."
         ('fiasco' is left untouched)
    2. Absolute remote URL:
         <remote fetch="..">  becomes  <remote fetch="https://github.com/L4Re">
       (Upstream resolves ".." against the manifest repository URL; with
       'ham init -f' there is no manifest URL, so we use an absolute base.)

  Rationale: the integration project keeps the L4Re source tree under
  sources/l4re/ instead of sources/l4/ for naming consistency.
  See docs/manifest.md and docs/conventions.md for details.

  This file is consumed by 'ham init -f' (see taskfiles/sources.yml).
-->
<manifest>
  <remote
    name="origin"
    fetch="https://github.com/L4Re"
    review="https://github.com/L4Re"
  />
  <default
    remote="origin"
  />
  <project name="acpica" path="l4re/pkg/acpica" />
  <project name="ada" path="l4re/pkg/ada" />
